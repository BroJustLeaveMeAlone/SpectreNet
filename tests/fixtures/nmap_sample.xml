<?xml version="1.0"?>
<nmaprun>
  <host>
    <address addr="192.168.1.45" addrtype="ipv4"/>
    <ports>
      <port protocol="tcp" portid="445">
        <state state="open"/>
        <service name="microsoft-ds" version="Samba 4.6"/>
